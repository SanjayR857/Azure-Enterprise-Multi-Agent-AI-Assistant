# Stage 1: Build Phase
# Use Node.js to build the React application
FROM node:18-alpine as build
WORKDIR /app
# Copy the package.json and install dependencies
COPY package*.json ./
RUN npm ci
# Copy the rest of your React code and compile it into static HTML/JS/CSS files
COPY . .
RUN npm run build

# Stage 2: Serve Phase
# Use an extremely lightweight Nginx web server image
FROM nginx:alpine
# Copy the static files built in Stage 1 into the folder Nginx serves from
COPY --from=build /app/dist /usr/share/nginx/html
# Copy our custom Nginx routing configuration
COPY nginx.conf /etc/nginx/conf.d/default.conf
# Expose port 80 (standard HTTP port)
EXPOSE 80
# Start the Nginx server in the foreground
CMD ["nginx", "-g", "daemon off;"]
